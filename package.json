{
  "private": true,
  "type": "module",
  "workspaces": [
    "engine/core",
    "engine/packages/*",
    "engine/mods/*"
  ],
  "scripts": {
    "dev:starter:server": "tsx engine/core/src/server/main.ts root.json",
    "dev:starter:front": "npm run dev -w @treenity/react",
    "schema": "tsx engine/core/src/schema/extract-schemas.ts engine/mods engine/packages",
    "test": "npm test --workspaces --if-present"
  },
  "dependencies": {
    "@treenity/core": "3.0.0",
    "@treenity/react": "3.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "onnxruntime-node": "1.24.2"
  }
}
